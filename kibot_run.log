# KiBot output for diff web page between commits
# https://kibot.readthedocs.io/en/latest/configuration/outputs/kiri.html

kibot:
  version: 1

outputs:
- name: html_kiri
  comment: 'KiRI webpage'
  type: kiri
  category: 'KiRI'
  dir: 'KiRI'
  layers: all
  options:
    keep_generated: true
    max_commits: 3
    revision: 'HEAD'
    zones: 'global'

definitions:
  NAME: html_kiri
  COMMENT: KiRi webpage
  DIR: KiRI (kibot - config_reader.py:683)
