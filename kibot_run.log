    # - variable: 'RELEASE_BODY_1.0.2'
    #   command: 'python3 kibot_resources/scripts/get_changelog.py -f CHANGELOG.md --extra-spaces --separators 35 --version 1.0.2'

    # - variable: 'RELEASE_TITLE_1.1.0'
